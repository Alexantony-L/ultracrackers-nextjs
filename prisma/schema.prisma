generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  slug      String?
  imageUrl  String?
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  imageUrl    String?
  price       Float
  mrp         Float?
  unit        String?
  categoryId  Int?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  category    Category? @relation(fields: [categoryId], references: [id])
}
